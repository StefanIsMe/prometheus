# prometheus local sandbox — layers on strix for tool additions
# Build: docker build -f containers/Dockerfile.local -t prometheus-sandbox:local .
FROM ghcr.io/usestrix/strix-sandbox:1.0.0

USER root

# Add missing tools from the scan pipeline
RUN apt-get update && \
    apt-get install -y --no-install-recommends whatweb && \
    apt-get autoremove -y && \
    apt-get autoclean && \
    rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

USER pentester
WORKDIR /workspace
